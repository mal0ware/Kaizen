# Box A — production environment template. Copy to .env on the server
# and fill in. NEVER commit the real .env.
#
#   cp .env.example .env
#   $EDITOR .env
#
# Generate passwords with:  openssl rand -hex 24

# --- Postgres ------------------------------------------------------------------
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=replace-with-openssl-rand

KAIZEN_DB_USER=kaizen
KAIZEN_DB_PASSWORD=replace-with-openssl-rand

VIXEN_DB_USER=vixen
VIXEN_DB_PASSWORD=replace-with-openssl-rand

# --- Kaizen --------------------------------------------------------------------
# Anthropic API key for the frontier tier. Leave blank to fall back to
# local-only / Claude Code auth per docs/decisions/0005-routing.md.
KAIZEN_ANTHROPIC_API_KEY=
KAIZEN_USE_CLAUDE_CODE_AUTH=false

# Tier-1 (cheap cloud) router target. Leave default unless you've wired
# DigitalOcean's Inference Engine or another OpenAI-compatible endpoint.
KAIZEN_USE_LOCAL_MODEL=false
KAIZEN_LOCAL_MODEL_ENDPOINT=http://localhost:11434
KAIZEN_FRONTIER_MODEL=claude-opus-4
KAIZEN_CHEAP_MODEL=claude-haiku-4
KAIZEN_LOCAL_MODEL=qwen2.5:7b

# Embeddings (pgvector). The local-Ollama default lines up with ADR 0007's
# on-demand home GPU worker — set the endpoint to the Tailscale name of
# the home box, e.g. http://desktop.tail-xxxx.ts.net:11434.
KAIZEN_EMBED_MODEL=nomic-embed-text
KAIZEN_VECTOR_DIM=768

KAIZEN_DISCORD_TOKEN=
KAIZEN_TALKATIVENESS=0.5

# --- Vixen ---------------------------------------------------------------------
DISCORD_TOKEN=
GUILD_ID=0

# --- Backups (used by deploy/backup.sh) ---------------------------------------
# Local destination is fine for now; point at a Spaces/S3 URL when you
# want offsite copies. See deploy/runbook.md.
RESTIC_REPOSITORY=/var/backups/box-a/restic
RESTIC_PASSWORD=replace-with-openssl-rand
