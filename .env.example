# Copy to .env and fill in. Everything here is OPTIONAL for the mock/dev path —
# `python -m kaizen` runs with no keys and no infra.

# Models / providers
KAIZEN_ANTHROPIC_API_KEY=
KAIZEN_USE_CLAUDE_CODE_AUTH=false
KAIZEN_USE_LOCAL_MODEL=false
KAIZEN_LOCAL_MODEL_ENDPOINT=http://localhost:11434
KAIZEN_FRONTIER_MODEL=claude-opus-4
KAIZEN_CHEAP_MODEL=claude-haiku-4
KAIZEN_LOCAL_MODEL=qwen2.5:7b

# Memory (semantic recall via a local Ollama embedding model)
KAIZEN_EMBED_MODEL=nomic-embed-text
KAIZEN_VECTOR_DIM=768

# Discord surface (Developer Portal -> your app -> Bot -> Token; enable Message Content Intent)
KAIZEN_DISCORD_TOKEN=

# Headless core daemon (`python -m kaizen serve`). Surfaces probe SERVICE_URL
# at startup: reachable -> thin HTTP client, otherwise embedded fallback.
KAIZEN_SERVICE_HOST=127.0.0.1
KAIZEN_SERVICE_PORT=8420
KAIZEN_SERVICE_URL=http://127.0.0.1:8420

# Self-state persistence: traits, skills, instincts, proposals, session
# snapshots as JSON files. Zero infra. Empty = in-memory (nothing survives).
KAIZEN_STATE_DIR=~/.kaizen/state

# Background cognition cadences, daemon only (seconds; 0 disables).
KAIZEN_SCRIBE_INTERVAL_SECONDS=300
KAIZEN_CURATOR_INTERVAL_SECONDS=600

# Infra — leave blank to use the in-memory store; set to use self-hosted/managed Postgres.
# Self-hosted via docker-compose.yml:
#   KAIZEN_DATABASE_URL=postgresql+asyncpg://kaizen:kaizen@localhost:5432/kaizen
#   KAIZEN_REDIS_URL=redis://localhost:6379/0
KAIZEN_DATABASE_URL=
KAIZEN_REDIS_URL=

# Behavior
KAIZEN_TALKATIVENESS=0.5
